{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "mathml-to-latex": ["../src/index.ts"],
      "data/*": ["../src/data/*"],
      "domain/*": ["../src/domain/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
