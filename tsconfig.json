{
  "compilerOptions": {
    "paths": {
      "data/*": ["./src/data/*"],
      "domain/*": ["./src/domain/*"]
    },
    "outDir": "dist",
    "target": "es2015",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "rootDir": "src",
    "types": ["jest"],
    "lib": ["es2017", "dom"],
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/__tests__/*"]
}
